<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--
    FileProvider exposes our internal photo directory to the camera app
    via content:// URIs so it can write JPEGs into filesDir/photos/ without
    needing legacy WRITE_EXTERNAL_STORAGE.
    -->
    <files-path
        name="photos"
        path="photos/" />
    <!-- Exported diagnostics log archives, shared via the «Журнал» button. -->
    <external-files-path
        name="exports"
        path="exports/" />
</paths>
