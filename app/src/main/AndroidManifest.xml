<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Bluetooth for Newton receiver SPP channels.
         minSdk 31 -> we do not need ACCESS_FINE_LOCATION for BT scan. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Foreground service for continuous GNSS data reception -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Internet for NTRIP. No cloud sync in MVP. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Optional: phone GPS as fallback reference; requested contextually.
         FINE requires COARSE per Lint CoarseFineLocation rule. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Optional: photo attachment for points; requested contextually -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Stakeout-in-tolerance haptic feedback. No runtime prompt required. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="true" />

    <!-- Camera is optional (point-photo attachment); declaring required=false keeps
         the app installable on Chromebooks and devices without a camera. -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <application
        android:name=".NewtonApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NewtonFieldApp"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.NewtonFieldApp"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- BT-004: GNSS foreground service. Lives in :gnss:data because it owns the
             NMEA pipeline, not just the Bluetooth socket. -->
        <service
            android:name="ru.newton.fieldapp.gnss.data.GnssForegroundService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!-- Hands a content:// URI to the camera app pointing at filesDir/photos/
             for point-photo capture. authority must match what the in-app code
             uses when calling FileProvider.getUriForFile. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="ru.newton.fieldapp.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
