# Copy to keystore.properties (git-ignored) and fill in real values for
# release-signed builds. Path is resolved relative to the repository root.
#
# To generate a fresh keystore:
#   keytool -genkeypair -v -keystore newton-release.jks -keyalg RSA \
#           -keysize 4096 -validity 10000 -alias newton-fieldapp
#
# Without this file, :app:assembleRelease falls back to debug signing.

storeFile=newton-release.jks
storePassword=CHANGE_ME
keyAlias=newton-fieldapp
keyPassword=CHANGE_ME
